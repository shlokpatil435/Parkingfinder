<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Pressed -->
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#0D1B5E"/>
            <corners android:radius="25dp"/>
        </shape>
    </item>

    <!-- Normal -->
    <item>
        <shape>
            <gradient
                android:startColor="#4F5BD5"
                android:endColor="#1A237E"
                android:angle="45"/>
            <corners android:radius="25dp"/>
        </shape>
    </item>

</selector>