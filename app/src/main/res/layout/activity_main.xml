<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/bg_gradient"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <ImageView
        android:id="@+id/profileIcon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:layout_alignParentEnd="true"
        android:layout_marginRight="50dp"
        android:layout_marginEnd="23dp"
        android:src="@drawable/ic_profile" />

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Smart Parking Finder"
        android:textColor="#FFFFFF"
        android:textSize="26sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/title"
        android:layout_marginTop="40dp"
        android:background="@drawable/card_premium"
        android:padding="24dp"
        android:orientation="vertical"
        android:elevation="12dp">

        <TextView
            android:id="@+id/txtSlots"
            android:text="🚗 Available Slots: 10"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A237E"
            android:layout_marginBottom="20dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/btnBook"
            android:text="Book Parking"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:backgroundTint="#3949AB"
            android:elevation="8dp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnExit"
            android:text="Exit Parking"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:backgroundTint="#3949AB"
            android:elevation="8dp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnReset"
            android:text="Reset Parking"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:backgroundTint="#5C6BC0"
            android:elevation="8dp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"/>

        <Button
            android:id="@+id/btnLogout"
            android:text="Logout"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:textStyle="bold"
            android:backgroundTint="#E53935"
            android:elevation="8dp"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

</RelativeLayout>